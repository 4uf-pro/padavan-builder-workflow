#!/bin/bash

############################################################
### Конфигурация репозитория Padavan-NG
############################################################

### URL-адрес репозитория исходного кода прошивки Padavan-NG
PADAVAN_REPO="https://gitlab.com/hadzhioglu/padavan-ng.git"

### Ветка Git для исходных кодов прошивки
PADAVAN_BRANCH="master"

### Коммит/тег для извлечения (используйте HEAD для последнего коммита)
PADAVAN_COMMIT="HEAD"

### URL для загрузки инструментов кросс-компиляции
### Содержит инструменты для сборки прошивки
PADAVAN_TOOLCHAIN_URL="https://gitlab.com/api/v4/projects/hadzhioglu%2Fpadavan-ng/packages/generic/toolchain/latest/toolchain.tzst"

############################################################
### Конфигурация репозитория тем оформления
############################################################

### URL-адрес репозитория тем для веб-интерфейса Padavan
PADAVAN_THEMES_REPO="https://gitlab.com/hadzhioglu/padavan-themes.git"

### Альтернативный облегченный репозиторий тем (по умолчанию отключен)
#PADAVAN_THEMES_REPO="https://gitlab.com/hadzhioglu/padavan-themes-lite.git"

### Ветка Git для тем оформления
PADAVAN_THEMES_BRANCH="main"

############################################################
### Выбор тем оформления
############################################################

### Массив выбора тем
### Раскомментируйте темы, которые следует включить в сборку прошивки
### Каждая тема увеличивает размер прошивки приблизительно на 100-200 КБ

PADAVAN_THEMES=(
  # blue        - Синяя цветовая тема
  # blue2       - Альтернативная синяя тема
  # grey        - Серая цветовая тема
  # grey2       - Альтернативная серая тема
  # white       - Белая/светлая тема
  # yellow      - Жёлтая/золотистая тема
)

############################################################
### Примечания по использованию
############################################################

### Для включения темы удалите символ '#' в начале соответствующей строки
### Пример: PADAVAN_THEMES=(blue grey white)

### При сборке нескольких тем учитывайте ограничения по размеру прошивки
### и доступную память целевого устройства