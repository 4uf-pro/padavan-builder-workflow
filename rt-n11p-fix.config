# ================================================
# Конфигурация сборки для ASUS RT-N11P (Ревизия A1)
# Процессор: MediaTek MT7620
# ================================================

# Производитель и модель устройства
CONFIG_VENDOR=ASUS
CONFIG_PRODUCT=MT7620

# Идентификатор продукта (максимум 23 ASCII символа)
CONFIG_FIRMWARE_PRODUCT_ID=RT-N11P

##################################################
# Конфигурация ядра Linux
##################################################

# Принудительная установка частоты процессора MT7620 на 600 МГц
CONFIG_FIRMWARE_CPU_600MHZ=y

# Включение режима энергосбережения процессора (снижение до 200 МГц при простое)
#CONFIG_FIRMWARE_CPU_SLEEP=y

# Выбор драйвера Wi-Fi для диапазона 2.4 ГГц
# 2.7 = MT7620 версия 2.7.2.0
# 3.0 = MT7620 версия 3.0.4.0
CONFIG_FIRMWARE_WIFI2_DRIVER=2.7

# Включение поддержки IPv6
CONFIG_FIRMWARE_ENABLE_IPV6=y

# Включение модулей XFRM (IPsec) и расширений iptables (~0.2 МБ)
#CONFIG_FIRMWARE_INCLUDE_XFRM=y

# Включение модулей QoS для управления сетевым трафиком (~0.2 МБ)
#CONFIG_FIRMWARE_INCLUDE_QOS=y

# Включение модуля IMQ для шейперов (незначительное снижение производительности) (~0.02 МБ)
#CONFIG_FIRMWARE_INCLUDE_IMQ=y

# Включение модуля IFB для шейперов (~0.03 МБ)
#CONFIG_FIRMWARE_INCLUDE_IFB=y

# Включение утилиты IPSet и соответствующих модулей ядра (~0.4 МБ)
#CONFIG_FIRMWARE_INCLUDE_IPSET=y

# Включение клиента NFS версии 3 (~0.5 МБ)
#CONFIG_FIRMWARE_INCLUDE_NFSC=y

# Включение клиента CIFS (SMB) (~0.2 МБ)
#CONFIG_FIRMWARE_INCLUDE_CIFS=y

# Включение механизма ускоренной пересылки пакетов
CONFIG_FIRMWARE_INCLUDE_SHORTCUT_FE=y

##################################################
# Конфигурация пользовательского пространства
##################################################

# Включение языковых пакетов для веб-интерфейса (увеличивает размер прошивки)
#CONFIG_FIRMWARE_INCLUDE_LANG_BR=y  # Бразильский португальский
#CONFIG_FIRMWARE_INCLUDE_LANG_CN=y  # Китайский
#CONFIG_FIRMWARE_INCLUDE_LANG_CZ=y  # Чешский
#CONFIG_FIRMWARE_INCLUDE_LANG_DA=y  # Датский
#CONFIG_FIRMWARE_INCLUDE_LANG_DE=y  # Немецкий
#CONFIG_FIRMWARE_INCLUDE_LANG_ES=y  # Испанский
#CONFIG_FIRMWARE_INCLUDE_LANG_FI=y  # Финский
#CONFIG_FIRMWARE_INCLUDE_LANG_FR=y  # Французский
#CONFIG_FIRMWARE_INCLUDE_LANG_NO=y  # Норвежский
#CONFIG_FIRMWARE_INCLUDE_LANG_PL=y  # Польский
CONFIG_FIRMWARE_INCLUDE_LANG_RU=y  # Русский
#CONFIG_FIRMWARE_INCLUDE_LANG_SV=y  # Шведский
CONFIG_FIRMWARE_INCLUDE_LANG_UK=y  # Украинский
# Английский язык включён по умолчанию

# Включение демона USB-over-IP (~0.05 МБ)
#CONFIG_FIRMWARE_INCLUDE_USBIP=y

# Включение утилиты tcpdump (~0.6 МБ)
#CONFIG_FIRMWARE_INCLUDE_TCPDUMP=y

# Включение утилиты socat (~0.3 МБ)
#CONFIG_FIRMWARE_INCLUDE_SOCAT=y

# Включение утилит ndisc6 и rdisc6 (~0.27 МБ)
#CONFIG_FIRMWARE_INCLUDE_NDISC6_RDISC6=y

# Включение только WINS сервера (~0.4 МБ)
#CONFIG_FIRMWARE_INCLUDE_WINS=y

# Включение системного журнала для серверов SMB и WINS (~0.3 МБ)
#CONFIG_FIRMWARE_INCLUDE_SMBD_SYSLOG=y

# Включение утилиты testparm для сервера SMB (~0.2 МБ)
#CONFIG_FIRMWARE_INCLUDE_TESTPARM=y

# Включение альтернативного клиента управления L2TP - RP-L2TP (~0.1 МБ)
CONFIG_FIRMWARE_INCLUDE_RPL2TP=y

# Включение поддержки аутентификации EAP-TTLS и EAP-PEAP (~1.2 МБ openssl, +0.04 МБ wpa_supplicant)
CONFIG_FIRMWARE_INCLUDE_EAP_PEAP=y

# Включение поддержки HTTPS для клиента DDNS (~1.2 МБ openssl)
CONFIG_FIRMWARE_INCLUDE_DDNS_SSL=y

# Включение поддержки HTTPS (~1.2 МБ openssl)
CONFIG_FIRMWARE_INCLUDE_HTTPS=y

# Включение SFTP-сервера (~1.2 МБ openssl, ~0.06 МБ sftp-server)
CONFIG_FIRMWARE_INCLUDE_SFTP=y

# Включение SSH-сервера dropbear (~0.3 МБ)
#CONFIG_FIRMWARE_INCLUDE_DROPBEAR=y

# Оптимизация симметричных шифров и хэшей в dropbear (~0.06 МБ)
#CONFIG_FIRMWARE_INCLUDE_DROPBEAR_FAST_CODE=y

# Включение OpenSSH вместо dropbear (~1.2 МБ openssl, ~1.0 МБ openssh)
CONFIG_FIRMWARE_INCLUDE_OPENSSH=y

# Включение OpenVPN (требуется IPv6) (~1.2 МБ openssl, ~0.4 МБ openvpn)
CONFIG_FIRMWARE_INCLUDE_OPENVPN=y

# Включение StrongSwan (~0.2 МБ модули XFRM, ~0.7 МБ strongswan)
#CONFIG_FIRMWARE_INCLUDE_SSWAN=y

# Включение модуля WireGuard VPN и утилиты
CONFIG_FIRMWARE_INCLUDE_WIREGUARD=y

# Включение модуля ядра AmneziaWG
#CONFIG_FIRMWARE_INCLUDE_AMNEZIAWG=y

# Включение эллиптических кривых (EC) в библиотеку openssl (~0.1 МБ)
#CONFIG_FIRMWARE_INCLUDE_OPENSSL_EC=y

# Включение исполняемого файла openssl для генерации сертификатов (~0.4 МБ)
#CONFIG_FIRMWARE_INCLUDE_OPENSSL_EXE=y

# Включение IPTV медиасервера xUPNPd (~0.3 МБ)
#CONFIG_FIRMWARE_INCLUDE_XUPNPD=y

# Включение прокси-сервера TOR (~2.8 МБ)
#CONFIG_FIRMWARE_INCLUDE_TOR=y

# Включение базы данных GeoIP для прокси TOR (~0.7 МБ)
#CONFIG_FIRMWARE_INCLUDE_TOR_GEOIP=y

# Включение базы данных GeoIP для IPv6 для прокси TOR (~0.6 МБ)
#CONFIG_FIRMWARE_INCLUDE_TOR_GEOIPV6=y

# Включение прокси-сервера Privoxy (~0.3 МБ)
#CONFIG_FIRMWARE_INCLUDE_PRIVOXY=y

# Включение прокси-сервера DNSCrypt (~0.5 МБ)
CONFIG_FIRMWARE_INCLUDE_DNSCRYPT=y

# Включение DNS-over-TLS (DoT) через Stubby (~0.5 МБ)
CONFIG_FIRMWARE_INCLUDE_STUBBY=y

# Включение DNS-over-HTTPS (DoH) через doh_proxy (~0.4 МБ)
#CONFIG_FIRMWARE_INCLUDE_DOH=y

# Включение поддержки Curl (~0.15 МБ)
#CONFIG_FIRMWARE_INCLUDE_CURL=y

# Включение поддержки QUIC в Curl (требуется openssl 3.5) (~0.4 МБ)
#CONFIG_FIRMWARE_INCLUDE_QUIC=y

# Включение поддержки QUIC в Curl с использованием ngtcp2 (требуется openssl 3.5) (~0.5 МБ)
#CONFIG_FIRMWARE_INCLUDE_QUIC_NGTCP2=y

# Использование альтернативных версий openssl вместо стандартной 3.0
# openssl 1.0.2u
#CONFIG_FIRMWARE_INCLUDE_OPENSSL_10=y
# openssl 1.1.1w
#CONFIG_FIRMWARE_INCLUDE_OPENSSL_11=y
# openssl 3.5
#CONFIG_FIRMWARE_INCLUDE_OPENSSL_35=y

# Включение поддержки WPAD
#CONFIG_FIRMWARE_INCLUDE_WPAD=y

# Включение поддержки сжатой памяти
CONFIG_FIRMWARE_INCLUDE_ZRAM=y

# Добавление пакета adb
#CONFIG_FIRMWARE_INCLUDE_ADB=y

# Включение поддержки LUA (~0.2 МБ)
#CONFIG_FIRMWARE_INCLUDE_LUA=y

# Включение Ethernet-туннелей EoIP поверх IP (~0.01 МБ)
#CONFIG_FIRMWARE_INCLUDE_EOIP=y

# Включение поддержки активации KMS (~0.06 МБ)
#CONFIG_FIRMWARE_INCLUDE_VLMCSD=y

# Включение поддержки iPerf3 (~0.13 МБ)
#CONFIG_FIRMWARE_INCLUDE_IPERF3=y

# Включение поддержки NFQWS (~0.1 МБ)
#CONFIG_FIRMWARE_INCLUDE_NFQWS=y

# Оптимизация размера образа trx
CONFIG_CC_OPTIMIZE_FOR_SIZE=y