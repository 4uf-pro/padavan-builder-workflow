### Производитель устройства и платформа (поддержка: Ralink RT3883/MT7620/MT7621/MT7628)
CONFIG_VENDOR=ASUS
CONFIG_PRODUCT=MT7628

### Идентификатор модели (выбор платы, до 23 символов ASCII)
CONFIG_FIRMWARE_PRODUCT_ID="RT-N11P"

############################################################
### Параметры ядра Linux
############################################################

### Режим энергосбережения процессора MT7628 (снижение частоты до 100 МГц при простое)
CONFIG_FIRMWARE_CPU_SLEEP=y

### Драйвер Wi-Fi 2.4 ГГц
### Версия 4.0 для MT7628 (4.0.1.3)
CONFIG_FIRMWARE_WIFI2_DRIVER=4.0

### Поддержка IPv6
CONFIG_FIRMWARE_ENABLE_IPV6=y

### Модули XFRM (IPsec) и расширения iptables (~0.2 МБ)
#CONFIG_FIRMWARE_INCLUDE_XFRM=y

### Модули управления качеством обслуживания (QoS) сети (~0.2 МБ)
CONFIG_FIRMWARE_INCLUDE_QOS=y

### Модуль IMQ для управления трафиком (незначительное влияние на производительность, ~0.02 МБ)
CONFIG_FIRMWARE_INCLUDE_IMQ=y

### Модуль IFB для управления трафиком (~0.03 МБ)
CONFIG_FIRMWARE_INCLUDE_IFB=y

### Утилита IPSet и соответствующие модули ядра (~0.4 МБ)
CONFIG_FIRMWARE_INCLUDE_IPSET=y

### Клиент NFSv3 (~0.5 МБ)
#CONFIG_FIRMWARE_INCLUDE_NFSC=y

### Клиент CIFS (SMB) (~0.2 МБ)
#CONFIG_FIRMWARE_INCLUDE_CIFS=y

### Механизм ускоренной пересылки пакетов
CONFIG_FIRMWARE_INCLUDE_SHORTCUT_FE=y

############################################################
### Пользовательские компоненты
############################################################

### Языковые пакеты веб-интерфейса (увеличивает размер прошивки)
#CONFIG_FIRMWARE_INCLUDE_LANG_BR=y    # Бразильский португальский
#CONFIG_FIRMWARE_INCLUDE_LANG_CN=y    # Китайский
#CONFIG_FIRMWARE_INCLUDE_LANG_CZ=y    # Чешский
#CONFIG_FIRMWARE_INCLUDE_LANG_DA=y    # Датский
#CONFIG_FIRMWARE_INCLUDE_LANG_DE=y    # Немецкий
#CONFIG_FIRMWARE_INCLUDE_LANG_ES=y    # Испанский
#CONFIG_FIRMWARE_INCLUDE_LANG_FI=y    # Финский
#CONFIG_FIRMWARE_INCLUDE_LANG_FR=y    # Французский
#CONFIG_FIRMWARE_INCLUDE_LANG_NO=y    # Норвежский
#CONFIG_FIRMWARE_INCLUDE_LANG_PL=y    # Польский
CONFIG_FIRMWARE_INCLUDE_LANG_RU=y    # Русский
#CONFIG_FIRMWARE_INCLUDE_LANG_SV=y    # Шведский
CONFIG_FIRMWARE_INCLUDE_LANG_UK=y    # Украинский

### Демон USB-over-IP (~0.05 МБ)
#CONFIG_FIRMWARE_INCLUDE_USBIP=y

### Утилита анализа трафика tcpdump (~0.6 МБ)
CONFIG_FIRMWARE_INCLUDE_TCPDUMP=y

### Утилита сетевых соединений socat (~0.3 МБ)
#CONFIG_FIRMWARE_INCLUDE_SOCAT=y

### Утилиты диагностики IPv6 ndisc6 и rdisc6 (~0.27 МБ)
#CONFIG_FIRMWARE_INCLUDE_NDISC6_RDISC6=y

### Сервер WINS (~0.4 МБ)
#CONFIG_FIRMWARE_INCLUDE_WINS=y

### Ведение логов для серверов SMB и WINS (~0.3 МБ)
#CONFIG_FIRMWARE_INCLUDE_SMBD_SYSLOG=y

### Утилита тестирования параметров SMB testparm (~0.2 МБ)
#CONFIG_FIRMWARE_INCLUDE_TESTPARM=y

### Альтернативный клиент управления L2TP RP-L2TP (~0.1 МБ)
CONFIG_FIRMWARE_INCLUDE_RPL2TP=y

### Поддержка аутентификации EAP-TTLS и EAP-PEAP (openssl ~1.2 МБ, wpa_supplicant +0.04 МБ)
CONFIG_FIRMWARE_INCLUDE_EAP_PEAP=y

### Поддержка HTTPS для динамического DNS (openssl ~1.2 МБ)
CONFIG_FIRMWARE_INCLUDE_DDNS_SSL=y

### Поддержка HTTPS (openssl ~1.2 МБ)
CONFIG_FIRMWARE_INCLUDE_HTTPS=y

### SFTP-сервер (openssl ~1.2 МБ, sftp-server ~0.06 МБ)
CONFIG_FIRMWARE_INCLUDE_SFTP=y

### SSH-сервер dropbear (~0.3 МБ)
#CONFIG_FIRMWARE_INCLUDE_DROPBEAR=y

### Ускорение симметричных шифров и хешей в dropbear (~0.06 МБ)
#CONFIG_FIRMWARE_INCLUDE_DROPBEAR_FAST_CODE=y

### SSH-сервер OpenSSH вместо dropbear (openssl ~1.2 МБ, openssh ~1.0 МБ)
CONFIG_FIRMWARE_INCLUDE_OPENSSH=y

### VPN OpenVPN (требуется IPv6, openssl ~1.2 МБ, openvpn ~0.4 МБ)
CONFIG_FIRMWARE_INCLUDE_OPENVPN=y

### VPN StrongSwan (модули XFRM ~0.2 МБ, strongswan ~0.7 МБ)
#CONFIG_FIRMWARE_INCLUDE_SSWAN=y

### Модуль VPN Wireguard и утилиты
CONFIG_FIRMWARE_INCLUDE_WIREGUARD=y

### Модуль ядра AmneziaWG
#CONFIG_FIRMWARE_INCLUDE_AMNEZIAWG=y

### Поддержка эллиптических кривых (EC) в библиотеке openssl (~0.1 МБ)
CONFIG_FIRMWARE_INCLUDE_OPENSSL_EC=y

### Исполняемый файл openssl для генерации сертификатов (~0.4 МБ)
CONFIG_FIRMWARE_INCLUDE_OPENSSL_EXE=y

### Медиасервер IPTV xUPNPd (~0.3 МБ)
CONFIG_FIRMWARE_INCLUDE_XUPNPD=y

### Прокси-сервер TOR (~2.8 МБ)
#CONFIG_FIRMWARE_INCLUDE_TOR=y

### База данных GeoIP для TOR (~0.7 МБ)
#CONFIG_FIRMWARE_INCLUDE_TOR_GEOIP=y

### База данных GeoIP IPv6 для TOR (~0.6 МБ)
#CONFIG_FIRMWARE_INCLUDE_TOR_GEOIPV6=y

### HTTP-прокси Privoxy (~0.3 МБ)
#CONFIG_FIRMWARE_INCLUDE_PRIVOXY=y

### Прокси DNSCrypt (~0.5 МБ)
CONFIG_FIRMWARE_INCLUDE_DNSCRYPT=y

### DNS-over-TLS (DoT) клиент Stubby (~0.5 МБ)
CONFIG_FIRMWARE_INCLUDE_STUBBY=y

### DNS-over-HTTPS (DoH) прокси doh_proxy (~0.4 МБ)
CONFIG_FIRMWARE_INCLUDE_DOH=y

### Библиотека сетевых запросов Curl (~0.15 МБ)
#CONFIG_FIRMWARE_INCLUDE_CURL=y

### Поддержка протокола QUIC в Curl (требуется openssl 3.5, ~0.4 МБ)
CONFIG_FIRMWARE_INCLUDE_QUIC=y

### Поддержка QUIC в Curl с использованием ngtcp2 (требуется openssl 3.5, ~0.5 МБ)
#CONFIG_FIRMWARE_INCLUDE_QUIC_NGTCP2=y

### Альтернативные версии библиотеки openssl (вместо стандартной 3.0)
### openssl 1.0.2u
#CONFIG_FIRMWARE_INCLUDE_OPENSSL_10=y
### openssl 1.1.1w
#CONFIG_FIRMWARE_INCLUDE_OPENSSL_11=y
### openssl 3.5
#CONFIG_FIRMWARE_INCLUDE_OPENSSL_35=y

### Поддержка автоматического определения прокси (WPAD)
#CONFIG_FIRMWARE_INCLUDE_WPAD=y

### Механизм сжатия оперативной памяти (zram)
CONFIG_FIRMWARE_INCLUDE_ZRAM=y

### Пакет отладки Android (adb)
#CONFIG_FIRMWARE_INCLUDE_ADB=y

### Язык сценариев LUA (~0.2 МБ)
#CONFIG_FIRMWARE_INCLUDE_LUA=y

### Ethernet-туннели поверх IP (EoIP, ~0.01 МБ)
#CONFIG_FIRMWARE_INCLUDE_EOIP=y

### Сервис активации KMS (~0.06 МБ)
#CONFIG_FIRMWARE_INCLUDE_VLMCSD=y

### Утилита тестирования пропускной способности iPerf3 (~0.13 МБ)
#CONFIG_FIRMWARE_INCLUDE_IPERF3=y

### Утилита обхода блокировок NFQWS (~0.1 МБ)
CONFIG_FIRMWARE_INCLUDE_NFQWS=y

### Оптимизация компилятора для уменьшения размера
CONFIG_CC_OPTIMIZE_FOR_SIZE=y