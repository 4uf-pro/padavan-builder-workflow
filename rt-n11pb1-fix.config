# ==================================================
# Build configuration for ASUS RT-N11P B1 (Revision B1)
# CPU: MediaTek MT7628
# ==================================================

# Device manufacturer and model
CONFIG_VENDOR=ASUS
CONFIG_PRODUCT=MT7628

# Product ID (maximum 23 ASCII characters)
CONFIG_FIRMWARE_PRODUCT_ID=RT-N11PB1

##################################################
# Linux kernel configuration
##################################################

# Enable MT7628 CPU power saving mode (reduces to 100 MHz at idle)
#CONFIG_FIRMWARE_CPU_SLEEP=y

# Wi-Fi driver selection for 2.4 GHz band
# 4.0 = MT7628 version 4.0.1.3
CONFIG_FIRMWARE_WIFI2_DRIVER=4.0

# Enable IPv6 support
CONFIG_FIRMWARE_ENABLE_IPV6=y

# Enable XFRM (IPsec) modules and iptables extensions (~0.2 MB)
#CONFIG_FIRMWARE_INCLUDE_XFRM=y

# Enable QoS modules for network traffic management (~0.2 MB)
#CONFIG_FIRMWARE_INCLUDE_QOS=y

# Enable IMQ module for shapers (minor performance impact) (~0.02 MB)
#CONFIG_FIRMWARE_INCLUDE_IMQ=y

# Enable IFB module for shapers (~0.03 MB)
#CONFIG_FIRMWARE_INCLUDE_IFB=y

# Enable IPSet utility and corresponding kernel modules (~0.4 MB)
#CONFIG_FIRMWARE_INCLUDE_IPSET=y

# Enable NFS client version 3 (~0.5 MB)
#CONFIG_FIRMWARE_INCLUDE_NFSC=y

# Enable CIFS (SMB) client (~0.2 MB)
#CONFIG_FIRMWARE_INCLUDE_CIFS=y

# Enable packet forwarding acceleration mechanism
CONFIG_FIRMWARE_INCLUDE_SHORTCUT_FE=y

##################################################
# User space configuration
##################################################

# Enable language packs for web interface (increases firmware size)
#CONFIG_FIRMWARE_INCLUDE_LANG_BR=y  # Brazilian Portuguese
#CONFIG_FIRMWARE_INCLUDE_LANG_CN=y  # Chinese
#CONFIG_FIRMWARE_INCLUDE_LANG_CZ=y  # Czech
#CONFIG_FIRMWARE_INCLUDE_LANG_DA=y  # Danish
#CONFIG_FIRMWARE_INCLUDE_LANG_DE=y  # German
#CONFIG_FIRMWARE_INCLUDE_LANG_ES=y  # Spanish
#CONFIG_FIRMWARE_INCLUDE_LANG_FI=y  # Finnish
#CONFIG_FIRMWARE_INCLUDE_LANG_FR=y  # French
#CONFIG_FIRMWARE_INCLUDE_LANG_NO=y  # Norwegian
#CONFIG_FIRMWARE_INCLUDE_LANG_PL=y  # Polish
CONFIG_FIRMWARE_INCLUDE_LANG_RU=y  # Russian
#CONFIG_FIRMWARE_INCLUDE_LANG_SV=y  # Swedish
CONFIG_FIRMWARE_INCLUDE_LANG_UK=y  # Ukrainian
# English language is enabled by default

# Enable USB-over-IP daemon (~0.05 MB)
#CONFIG_FIRMWARE_INCLUDE_USBIP=y

# Enable tcpdump utility (~0.6 MB)
#CONFIG_FIRMWARE_INCLUDE_TCPDUMP=y

# Enable socat utility (~0.3 MB)
#CONFIG_FIRMWARE_INCLUDE_SOCAT=y

# Enable ndisc6 and rdisc6 utilities (~0.27 MB)
#CONFIG_FIRMWARE_INCLUDE_NDISC6_RDISC6=y

# Enable WINS server only (~0.4 MB)
#CONFIG_FIRMWARE_INCLUDE_WINS=y

# Enable syslog for SMB and WINS servers (~0.3 MB)
#CONFIG_FIRMWARE_INCLUDE_SMBD_SYSLOG=y

# Enable testparm utility for SMB server (~0.2 MB)
#CONFIG_FIRMWARE_INCLUDE_TESTPARM=y

# Enable alternative L2TP control client - RP-L2TP (~0.1 MB)
CONFIG_FIRMWARE_INCLUDE_RPL2TP=y

# Enable EAP-TTLS and EAP-PEAP authentication support (~1.2 MB openssl, +0.04 MB wpa_supplicant)
CONFIG_FIRMWARE_INCLUDE_EAP_PEAP=y

# Enable HTTPS support for DDNS client (~1.2 MB openssl)
CONFIG_FIRMWARE_INCLUDE_DDNS_SSL=y

# Enable HTTPS support (~1.2 MB openssl)
CONFIG_FIRMWARE_INCLUDE_HTTPS=y

# Enable SFTP server (~1.2 MB openssl, ~0.06 MB sftp-server)
CONFIG_FIRMWARE_INCLUDE_SFTP=y

# Enable dropbear SSH server (~0.3 MB)
#CONFIG_FIRMWARE_INCLUDE_DROPBEAR=y

# Optimize symmetric ciphers and hashes in dropbear (~0.06 MB)
#CONFIG_FIRMWARE_INCLUDE_DROPBEAR_FAST_CODE=y

# Enable OpenSSH instead of dropbear (~1.2 MB openssl, ~1.0 MB openssh)
CONFIG_FIRMWARE_INCLUDE_OPENSSH=y

# Enable OpenVPN (requires IPv6) (~1.2 MB openssl, ~0.4 MB openvpn)
CONFIG_FIRMWARE_INCLUDE_OPENVPN=y

# Enable StrongSwan (~0.2 MB XFRM modules, ~0.7 MB strongswan)
#CONFIG_FIRMWARE_INCLUDE_SSWAN=y

# Enable WireGuard VPN module and utility
CONFIG_FIRMWARE_INCLUDE_WIREGUARD=y

# Enable AmneziaWG kernel module
#CONFIG_FIRMWARE_INCLUDE_AMNEZIAWG=y

# Enable elliptic curves (EC) in openssl library (~0.1 MB)
#CONFIG_FIRMWARE_INCLUDE_OPENSSL_EC=y

# Enable openssl executable for certificate generation (~0.4 MB)
#CONFIG_FIRMWARE_INCLUDE_OPENSSL_EXE=y

# Enable IPTV media server xUPNPd (~0.3 MB)
#CONFIG_FIRMWARE_INCLUDE_XUPNPD=y

# Enable TOR proxy server (~2.8 MB)
#CONFIG_FIRMWARE_INCLUDE_TOR=y

# Enable GeoIP database for TOR proxy (~0.7 MB)
#CONFIG_FIRMWARE_INCLUDE_TOR_GEOIP=y

# Enable GeoIP database for IPv6 for TOR proxy (~0.6 MB)
#CONFIG_FIRMWARE_INCLUDE_TOR_GEOIPV6=y

# Enable Privoxy proxy server (~0.3 MB)
#CONFIG_FIRMWARE_INCLUDE_PRIVOXY=y

# Enable DNSCrypt proxy server (~0.5 MB)
CONFIG_FIRMWARE_INCLUDE_DNSCRYPT=y

# Enable DNS-over-TLS (DoT) via Stubby (~0.5 MB)
CONFIG_FIRMWARE_INCLUDE_STUBBY=y

# Enable DNS-over-HTTPS (DoH) via doh_proxy (~0.4 MB)
#CONFIG_FIRMWARE_INCLUDE_DOH=y

# Enable Curl support (~0.15 MB)
#CONFIG_FIRMWARE_INCLUDE_CURL=y

# Enable QUIC support in Curl (requires openssl 3.5) (~0.4 MB)
#CONFIG_FIRMWARE_INCLUDE_QUIC=y

# Enable QUIC support in Curl using ngtcp2 (requires openssl 3.5) (~0.5 MB)
#CONFIG_FIRMWARE_INCLUDE_QUIC_NGTCP2=y

# Use alternative openssl versions instead of standard 3.0
# openssl 1.0.2u
#CONFIG_FIRMWARE_INCLUDE_OPENSSL_10=y
# openssl 1.1.1w
#CONFIG_FIRMWARE_INCLUDE_OPENSSL_11=y
# openssl 3.5
#CONFIG_FIRMWARE_INCLUDE_OPENSSL_35=y

# Enable WPAD support
#CONFIG_FIRMWARE_INCLUDE_WPAD=y

# Enable compressed memory support
CONFIG_FIRMWARE_INCLUDE_ZRAM=y

# Add adb package
#CONFIG_FIRMWARE_INCLUDE_ADB=y

# Enable LUA support (~0.2 MB)
#CONFIG_FIRMWARE_INCLUDE_LUA=y

# Enable EoIP Ethernet tunnels over IP (~0.01 MB)
#CONFIG_FIRMWARE_INCLUDE_EOIP=y

# Enable KMS activation support (~0.06 MB)
#CONFIG_FIRMWARE_INCLUDE_VLMCSD=y

# Enable iPerf3 support (~0.13 MB)
#CONFIG_FIRMWARE_INCLUDE_IPERF3=y

# Enable NFQWS support (~0.1 MB)
#CONFIG_FIRMWARE_INCLUDE_NFQWS=y

# Optimize trx image size
CONFIG_CC_OPTIMIZE_FOR_SIZE=y